#!/usr/bin/env bash
# SPDX-License-Identifier: GPL-3.0-or-later
# Copyright (C) 2026 repodash contributors
# repodash — multi-repo dashboard: git status, TODOs, audits, roadmap, SonarQube.
#
# Parity port of repodash.py. Both build the SAME per-repo model and emit
# byte-compatible `--json` (the parity contract; compared semantically in tests).
# Invariant: render is derived; JSON is canonical.
#
# Targets bash 3.2 (stock macOS) and degrades gracefully without grep -P.

# ── colors (real ESC bytes so all output uses printf %s, never %b) ───────────
RED=''; YELLOW=''; GREEN=''; BLUE=''; CYAN=''; MAGENTA=''; BOLD=''; DIM=''; NC=''
set_palette() {  # $1 = 1 to enable color
  if [ "$1" = "1" ]; then
    RED=$'\033[0;31m'; YELLOW=$'\033[1;33m'; GREEN=$'\033[0;32m'
    BLUE=$'\033[0;34m'; CYAN=$'\033[0;36m'; MAGENTA=$'\033[0;35m'
    BOLD=$'\033[1m'; DIM=$'\033[2m'; NC=$'\033[0m'
  else
    RED=''; YELLOW=''; GREEN=''; BLUE=''; CYAN=''; MAGENTA=''
    BOLD=''; DIM=''; NC=''
  fi
}

# ── defaults / config ────────────────────────────────────────────────────────
SCHEMA_VERSION=1
BASE_DIR="${REPODASH_DIR:-$HOME/git}"
SONAR_URL="${SONAR_URL:-}"
SONAR_TOKEN="${SONAR_TOKEN:-}"
DEPTH="${REPODASH_DEPTH:-3}"
MAX_TODOS="${REPODASH_MAX_TODOS:-10}"
WIDTH_OVERRIDE=""
AS_JSON=0
NO_COLOR_FLAG=0
INSECURE=0
ONLY_DIRTY=0

MAX_AUDIT_FILES=5
AUDIT_ITEMS_PER_FILE=8
ARCHIVE_ITEMS=5
ROADMAP_ITEMS_PER_FILE=15

SHOW_GIT=1; SHOW_TODOS=1; SHOW_AUDIT=1; SHOW_ROADMAP=1; SHOW_SONAR=1

usage() {
  cat <<'EOF'
repodash — multi-repo dashboard

USAGE
  repodash [OPTIONS] [DIR]

OPTIONS
  --git --todos --audit --roadmap --sonar   show only those sections
  --dirty            only repos with something to report
  --json             emit the full model as JSON (ignores section flags)
  --no-color         disable ANSI color
  --insecure         skip TLS verification for Sonar
  --depth N          repo discovery depth (default 3)
  --max-todos N      max TODO lines shown per repo (default 10)
  --width N          override terminal width
  -h, --help         show this help

ENVIRONMENT
  REPODASH_DIR, SONAR_URL, SONAR_TOKEN, REPODASH_DEPTH,
  REPODASH_MAX_TODOS, NO_COLOR, COLUMNS
EOF
  exit 0
}

# ── arg parsing ──────────────────────────────────────────────────────────────
SECTION_FLAGS=0
ARGS=("$@")
while [ $# -gt 0 ]; do
  case "$1" in
    -h|--help) usage ;;
    --dirty) ONLY_DIRTY=1 ;;
    --json) AS_JSON=1 ;;
    --no-color) NO_COLOR_FLAG=1 ;;
    --insecure) INSECURE=1 ;;
    --depth) shift; DEPTH="$1" ;;
    --max-todos) shift; MAX_TODOS="$1" ;;
    --width) shift; WIDTH_OVERRIDE="$1" ;;
    --git|--todos|--audit|--roadmap|--sonar) SECTION_FLAGS=1 ;;
    -*) printf 'Unknown option: %s\n' "$1" >&2; exit 1 ;;
    *) BASE_DIR="$1" ;;
  esac
  shift
done

if [ "$SECTION_FLAGS" -eq 1 ] && [ "$AS_JSON" -eq 0 ]; then
  SHOW_GIT=0; SHOW_TODOS=0; SHOW_AUDIT=0; SHOW_ROADMAP=0; SHOW_SONAR=0
  for a in "${ARGS[@]}"; do
    case "$a" in
      --git) SHOW_GIT=1 ;;
      --todos) SHOW_TODOS=1 ;;
      --audit) SHOW_AUDIT=1 ;;
      --roadmap) SHOW_ROADMAP=1 ;;
      --sonar) SHOW_SONAR=1 ;;
    esac
  done
fi

# ── PCRE capability probe + TODO pattern selection ───────────────────────────
if printf '' | grep -qP '' 2>/dev/null; then HAS_PCRE=1; else HAS_PCRE=0; fi
# testability hook: force the POSIX-ERE path even where grep -P is available
[ -n "${REPODASH_FORCE_ERE:-}" ] && HAS_PCRE=0
if [ "$HAS_PCRE" -eq 1 ]; then
  TODO_FLAGS="-nP"
  TODO_PAT='(//|#|<!--|--|\*)\s*(TODO|FIXME|HACK)\b'
else
  # ERE lacks \b/\s/\*; trailing class stands in for \b. Whole-line match only
  # (never -o) so the consumed boundary char doesn't corrupt captured text.
  TODO_FLAGS="-nE"
  TODO_PAT='(//|#|<!--|--|[*])[[:space:]]*(TODO|FIXME|HACK)([^A-Za-z0-9_]|$)'
fi
CHECKBOX_PAT='^[[:space:]]*[-*] \[ \]'

# ── small helpers ────────────────────────────────────────────────────────────
abspath() { ( cd "$1" 2>/dev/null && pwd ) || printf '%s' "$1"; }

rstrip() { local s="$1"; printf '%s' "${s%"${s##*[![:space:]]}"}"; }

strip_checkbox() {  # remove leading bullet marker + a single trailing CR
  local t; t=$(printf '%s' "$1" | sed -E 's/^[[:space:]]*[-*] \[ \] //')
  printf '%s' "${t%$'\r'}"
}

repeat_char() {  # $1 char, $2 count
  local c="$1" n="$2" out="" i=0
  while [ "$i" -lt "$n" ]; do out="$out$c"; i=$((i + 1)); done
  printf '%s' "$out"
}

json_str() {  # escape and double-quote a JSON string (matches Python json.dumps)
  local s="$1"
  s=${s//\\/\\\\}; s=${s//\"/\\\"}
  s=${s//$'\t'/\\t}; s=${s//$'\r'/\\r}; s=${s//$'\n'/\\n}
  s=${s//$'\b'/\\b}; s=${s//$'\f'/\\f}
  # remaining JSON-required control chars (U+0000–U+001F) seen in source text
  s=${s//$'\033'/\\u001b}; s=${s//$'\v'/\\u000b}
  printf '"%s"' "$s"
}

join_json() {  # $1 separator, remaining args joined
  local sep="$1"; shift
  local out="" e first=1
  for e in "$@"; do
    if [ "$first" -eq 1 ]; then out="$e"; first=0; else out="$out$sep$e"; fi
  done
  printf '%s' "$out"
}

parse_branch() {
  local first="$1" rest
  case "$first" in '## '*) rest=${first#'## '} ;; *) printf ''; return ;; esac
  case "$rest" in
    'No commits yet on '*) rest=${rest#'No commits yet on '} ;;
    'Initial commit on '*) rest=${rest#'Initial commit on '} ;;
  esac
  rest=${rest%%...*}; rest=${rest%% *}
  printf '%s' "$rest"
}

list_open_items() {  # repo, file -> lines "lineno<TAB>text" (bullet stripped)
  local repo="$1" f="$2" m lineno text
  while IFS= read -r m; do
    lineno=${m%%:*}; text=${m#*:}
    text=$(strip_checkbox "$text")
    printf '%s\t%s\n' "$lineno" "$text"
  done < <(grep -nE "$CHECKBOX_PAT" "$f" 2>/dev/null)
}

# ── file discovery (one find per category; mirrors repodash.py collect) ──────
find_code_files() {
  find "$1" -type f -size -500k \
    -not -path '*/.git/*' -not -path '*/node_modules/*' -not -path '*/vendor/*' \
    -not -path '*/.next/*' -not -path '*/dist/*' -not -path '*/build/*' \
    -not -path '*/__pycache__/*' -not -path '*/.cache/*' -not -path '*/.claude/*' \
    -not -path '*/coverage/*' -not -path '*/test-results/*' -not -path '*/generated/*' \
    -not -path '*/.venv/*' -not -path '*/venv/*' -not -path '*/.tox/*' \
    \( -name '*.ts' -o -name '*.tsx' -o -name '*.js' -o -name '*.jsx' \
       -o -name '*.mjs' -o -name '*.cjs' -o -name '*.py' -o -name '*.go' \
       -o -name '*.rb' -o -name '*.rs' -o -name '*.java' -o -name '*.kt' \
       -o -name '*.swift' -o -name '*.dart' -o -name '*.php' -o -name '*.c' \
       -o -name '*.cpp' -o -name '*.h' -o -name '*.sh' -o -name '*.bash' \
       -o -name '*.vue' -o -name '*.svelte' -o -name '*.sql' -o -name '*.tf' \
       -o -name '*.yaml' -o -name '*.yml' -o -name '*.toml' \) 2>/dev/null | sort
}

find_audit_files() {
  find "$1" -maxdepth 5 -type f \
    -not -path '*/.git/*' -not -path '*/node_modules/*' -not -path '*/coverage/*' \
    -not -path '*/dist/*' -not -path '*/test-results/*' -not -path '*/.claude/*' \
    \( -iname '*.md' -o -iname '*.txt' \) \
    -a \( -iname '*audit*' -o -iname '*security-review*' -o -iname 'SECURITY*' \
       -o -iname '*vulnerability*' -o -iname '*pentest*' \) 2>/dev/null | sort
}

find_roadmap_files() {
  find "$1" -maxdepth 3 -type f \
    -not -path '*/.git/*' -not -path '*/node_modules/*' \
    \( -iname 'ROADMAP.md' -o -iname 'TODO.md' -o -iname 'BACKLOG.md' \) \
    2>/dev/null | sort
}

# ── section: git ─────────────────────────────────────────────────────────────
# sets G_AHEAD G_BEHIND G_BRANCH G_DIRTY G_FILES_JSON G_FILES_RAW(array)
git_collect() {
  local repo="$1" sb first line st pa
  sb=$(git -C "$repo" status -sb 2>/dev/null)
  first=$(printf '%s\n' "$sb" | head -1)
  G_BRANCH=$(parse_branch "$first")
  G_AHEAD=$(printf '%s' "$first" | sed -n 's/.*ahead \([0-9][0-9]*\).*/\1/p'); G_AHEAD=${G_AHEAD:-0}
  G_BEHIND=$(printf '%s' "$first" | sed -n 's/.*behind \([0-9][0-9]*\).*/\1/p'); G_BEHIND=${G_BEHIND:-0}
  local els=()
  G_FILES_RAW=()
  while IFS= read -r line; do
    [ -z "$line" ] && continue
    st=${line:0:2}; pa=${line:3}
    els+=("$(printf '{"path":%s,"status":%s}' "$(json_str "$pa")" "$(json_str "$st")")")
    G_FILES_RAW+=("$st"$'\t'"$pa")
  done < <(git -C "$repo" status --porcelain 2>/dev/null)
  if [ "${#els[@]}" -gt 0 ]; then G_DIRTY=true; else G_DIRTY=false; fi
  G_FILES_JSON="[$(join_json , "${els[@]}")]"
}

git_json() {
  git_collect "$1"
  printf '{"ahead":%d,"behind":%d,"branch":%s,"dirty":%s,"dirty_files":%s}' \
    "$G_AHEAD" "$G_BEHIND" "$(json_str "$G_BRANCH")" "$G_DIRTY" "$G_FILES_JSON"
}

# ── section: todos ───────────────────────────────────────────────────────────
# sets T_TOTAL and T_ITEMS_JSON (array elements), and T_ITEMS_RAW (array of "path:line:text")
todos_collect() {
  local repo="$1" f rel m lineno content
  local els=() raw=()
  while IFS= read -r f; do
    [ -z "$f" ] && continue
    rel=${f#"$repo"/}
    while IFS= read -r m; do
      lineno=${m%%:*}; content=${m#*:}
      content=$(rstrip "$content")
      els+=("$(printf '{"line":%d,"path":%s,"text":%s}' "$lineno" "$(json_str "$rel")" "$(json_str "$content")")")
      raw+=("$rel:$lineno:$content")
    done < <(grep $TODO_FLAGS "$TODO_PAT" "$f" 2>/dev/null)
  done < <(find_code_files "$repo")
  T_TOTAL=${#els[@]}
  T_ITEMS_JSON="[$(join_json , "${els[@]}")]"
  T_ITEMS_RAW=("${raw[@]}")
}

todos_json() {
  todos_collect "$1"
  local shown=$T_TOTAL
  [ "$shown" -gt "$MAX_TODOS" ] && shown=$MAX_TODOS
  printf '{"items":%s,"shown":%d,"total":%d}' "$T_ITEMS_JSON" "$shown" "$T_TOTAL"
}

# ── section: audit ───────────────────────────────────────────────────────────
audit_json() {
  local repo="$1" f base
  local active=() archive=()
  while IFS= read -r f; do
    [ -z "$f" ] && continue
    base=$(basename "$f")
    if printf '%s' "$base" | grep -qE '^[0-9]{4}-[0-9]{2}-[0-9]{2}'; then
      archive+=("$f")
    else
      active+=("$f")
    fi
  done < <(find_audit_files "$repo")

  local fels=() gst rel items il lineno text
  local af
  for af in "${active[@]}"; do
    gst=$(git -C "$repo" status -s -- "$af" 2>/dev/null)
    gst=$(printf '%s' "$gst" | sed 's/^[[:space:]]*//'); gst=${gst:0:2}; gst=$(rstrip "$gst")
    rel=${af#"$repo"/}
    items=()
    while IFS=$'\t' read -r lineno text; do
      [ -z "$lineno" ] && continue
      items+=("$(printf '{"line":%d,"path":%s,"text":%s}' "$lineno" "$(json_str "$rel")" "$(json_str "$text")")")
    done < <(list_open_items "$repo" "$af")
    fels+=("$(printf '{"items":[%s],"path":%s,"status":%s}' "$(join_json , "${items[@]}")" "$(json_str "$rel")" "$(json_str "$gst")")")
  done

  local archive_json=null
  if [ "${#archive[@]}" -gt 0 ]; then
    local latest="${archive[$((${#archive[@]} - 1))]}"
    local mr; mr=$(basename "$latest")
    local total=0 cnt
    for af in "${archive[@]}"; do
      cnt=$(list_open_items "$repo" "$af" | grep -c . )
      total=$((total + cnt))
    done
    local rrel="${latest#"$repo"/}" rels=()
    while IFS=$'\t' read -r lineno text; do
      [ -z "$lineno" ] && continue
      rels+=("$(printf '{"line":%d,"path":%s,"text":%s}' "$lineno" "$(json_str "$rrel")" "$(json_str "$text")")")
    done < <(list_open_items "$repo" "$latest")
    archive_json=$(printf '{"count":%d,"most_recent":%s,"open_items_total":%d,"recent_items":[%s]}' \
      "${#archive[@]}" "$(json_str "$mr")" "$total" "$(join_json , "${rels[@]}")")
  fi

  printf '{"archive":%s,"files":[%s]}' "$archive_json" "$(join_json , "${fels[@]}")"
}

# ── section: roadmap ─────────────────────────────────────────────────────────
roadmap_json() {
  local repo="$1" f rel lineno text
  local fels=()
  while IFS= read -r f; do
    [ -z "$f" ] && continue
    rel=${f#"$repo"/}
    local items=()
    while IFS=$'\t' read -r lineno text; do
      [ -z "$lineno" ] && continue
      items+=("$(printf '{"line":%d,"path":%s,"text":%s}' "$lineno" "$(json_str "$rel")" "$(json_str "$text")")")
    done < <(list_open_items "$repo" "$f")
    if [ "${#items[@]}" -gt 0 ]; then
      fels+=("$(printf '{"items":[%s],"path":%s}' "$(join_json , "${items[@]}")" "$(json_str "$rel")")")
    fi
  done < <(find_roadmap_files "$repo")
  printf '{"files":[%s]}' "$(join_json , "${fels[@]}")"
}

# ── section: sonar ───────────────────────────────────────────────────────────
# sets S_CONFIGURED S_OK S_ERR S_KEY  and parallel arrays S_MK[] S_MV[]
sonar_collect() {
  local repo="$1" props="$repo/sonar-project.properties"
  S_CONFIGURED=false; S_OK=null; S_ERR=""; S_KEY=""; S_MK=(); S_MV=()
  [ -f "$props" ] || return 0
  S_CONFIGURED=true
  local key host
  key=$(grep -E '^sonar\.projectKey\s*=' "$props" 2>/dev/null | head -1 | sed 's/^[^=]*=//' | tr -d ' \r')
  host=$(grep -E '^sonar\.host\.url\s*=' "$props" 2>/dev/null | head -1 | sed 's/^[^=]*=//' | tr -d ' \r')
  S_KEY="$key"
  local url="${SONAR_URL:-$host}"
  if [ -z "$url" ]; then
    S_OK=false; S_ERR="sonar-project.properties found — set SONAR_URL to fetch stats"; return 0
  fi
  if [ -z "$key" ]; then
    S_OK=false; S_ERR="sonar.projectKey missing in sonar-project.properties"; S_KEY=""; return 0
  fi
  local kflag=()
  [ "$INSECURE" -eq 1 ] && kflag=(-k)
  local metrics="bugs,vulnerabilities,code_smells,coverage,duplicated_lines_density,security_hotspots"
  local api="${url}/api/measures/component?component=${key}&metricKeys=${metrics}"
  # Pass url + credentials through a curl config on stdin (-K -) so the token
  # never appears in argv (visible to other users via ps/proc), matching the
  # Python implementation's Authorization-header approach.
  local resp http body
  resp=$(
    { printf 'url = "%s"\n' "$api"
      [ -n "$SONAR_TOKEN" ] && printf 'user = "%s:"\n' "$SONAR_TOKEN"
    } | curl -s --max-time 10 -w '\n%{http_code}' "${kflag[@]}" -K - 2>/dev/null
  ) || { S_OK=false; S_ERR="API unreachable (${url})"; return 0; }
  http=${resp##*$'\n'}; body=${resp%$'\n'*}
  if [ "$http" != "200" ]; then
    local err; err=$(printf '%s' "$body" | jq -r '[.errors[].msg] | join("; ") // empty' 2>/dev/null)
    [ -z "$err" ] && err="HTTP ${http}"
    S_OK=false; S_ERR="$err"; return 0
  fi
  if ! printf '%s' "$body" | jq -e '.component.measures' >/dev/null 2>&1; then
    S_OK=false; S_ERR="unexpected response"; return 0
  fi
  S_OK=true
  local mv k v
  while IFS= read -r mv; do
    k=${mv%% *}; v=${mv#* }
    if printf '%s' "$v" | grep -qE '^-?[0-9]+$' || printf '%s' "$v" | grep -qE '^-?[0-9]*\.[0-9]+$'; then
      S_MK+=("$k"); S_MV+=("$v")
    fi
  done < <(printf '%s' "$body" | jq -r '.component.measures[] | "\(.metric) \(.value)"' 2>/dev/null)
}

sonar_metric() {  # $1 key -> value or "-"
  local i=0
  while [ "$i" -lt "${#S_MK[@]}" ]; do
    [ "${S_MK[$i]}" = "$1" ] && { printf '%s' "${S_MV[$i]}"; return; }
    i=$((i + 1))
  done
  printf '%s' '-'
}

sonar_json() {
  sonar_collect "$1"
  local metrics_json=null
  if [ "$S_OK" = "true" ]; then
    local els=() i=0
    while [ "$i" -lt "${#S_MK[@]}" ]; do
      els+=("$(printf '%s:%s' "$(json_str "${S_MK[$i]}")" "${S_MV[$i]}")")
      i=$((i + 1))
    done
    metrics_json="{$(join_json , "${els[@]}")}"
  fi
  local key_json=null; [ -n "$S_KEY" ] && key_json=$(json_str "$S_KEY")
  local err_json=null; [ -n "$S_ERR" ] && err_json=$(json_str "$S_ERR")
  printf '{"configured":%s,"error":%s,"metrics":%s,"ok":%s,"project_key":%s}' \
    "$S_CONFIGURED" "$err_json" "$metrics_json" "$S_OK" "$key_json"
}

# ── repo model + json document ───────────────────────────────────────────────
repo_json() {
  local repo="$1" name; name=$(basename "$repo")
  printf '{"audit":%s,"git":%s,"name":%s,"path":%s,"roadmap":%s,"sonar":%s,"todos":%s}' \
    "$(audit_json "$repo")" "$(git_json "$repo")" "$(json_str "$name")" \
    "$(json_str "$(abspath "$repo")")" "$(roadmap_json "$repo")" \
    "$(sonar_json "$repo")" "$(todos_json "$repo")"
}

# ── repo discovery ───────────────────────────────────────────────────────────
discover_repos() {
  local raw=() r k keep
  while IFS= read -r r; do
    raw+=("${r%/.git}")
  done < <(find "$BASE_DIR" -maxdepth "$((DEPTH + 1))" -type d -name .git 2>/dev/null | sort)
  REPOS=()
  for r in "${raw[@]}"; do
    keep=1
    for k in "${REPOS[@]}"; do
      case "$r" in "$k"/*) keep=0; break ;; esac
    done
    [ "$keep" -eq 1 ] && REPOS+=("$r")
  done
}

# ── rendering (mirrors repodash.py render*) ──────────────────────────────────
RENDER_OUT=""
emit() { RENDER_OUT="$RENDER_OUT$1"$'\n'; }
row() { emit "  ${BOLD}${DIM}$(printf '%-9s' "$1")${NC} $2"; }

render_repo() {
  local repo="$1" name; name=$(basename "$repo")
  local has=0 body=""
  RENDER_OUT=""

  # header
  local side=$(( (WIDTH - (${#name} + 4) - 2) / 2 ))
  [ "$side" -lt 0 ] && side=0
  local dash; dash=$(repeat_char '─' "$side")
  emit ""
  emit "${BOLD}${CYAN}╭${dash}${NC}${BOLD} ${name} ${NC}${BOLD}${CYAN}${dash}${NC}"

  local section_out="$RENDER_OUT"; RENDER_OUT=""

  if [ "$SHOW_GIT" -eq 1 ]; then
    git_collect "$repo"
    if [ "$G_DIRTY" = "true" ]; then
      has=1
      local label="git" ab="" st pa first=1
      [ "$G_AHEAD" != "0" ] && ab="ahead $G_AHEAD"
      [ "$G_BEHIND" != "0" ] && { [ -n "$ab" ] && ab="$ab behind $G_BEHIND" || ab="behind $G_BEHIND"; }
      [ -n "$ab" ] && label="git($ab)"
      for line in "${G_FILES_RAW[@]}"; do
        st=${line%%$'\t'*}; pa=${line#*$'\t'}
        if [ "$first" -eq 1 ]; then row "$label" "$st $pa"; first=0; else row "" "$st $pa"; fi
      done
    fi
  fi

  if [ "$SHOW_TODOS" -eq 1 ]; then
    todos_collect "$repo"
    if [ "$T_TOTAL" -gt 0 ]; then
      has=1
      local label="todo" i=0 text
      while [ "$i" -lt "$T_TOTAL" ] && [ "$i" -lt "$MAX_TODOS" ]; do
        text="${T_ITEMS_RAW[$i]}"
        [ "${#text}" -gt 120 ] && text="${text:0:120}…"
        row "$label" "${YELLOW}${text}${NC}"
        label=""; i=$((i + 1))
      done
      if [ "$T_TOTAL" -gt "$MAX_TODOS" ]; then
        row "" "${DIM}… and $((T_TOTAL - MAX_TODOS)) more${NC}"
      fi
    fi
  fi

  if [ "$SHOW_AUDIT" -eq 1 ]; then
    render_audit "$repo" && has=1
  fi
  if [ "$SHOW_ROADMAP" -eq 1 ]; then
    render_roadmap "$repo" && has=1
  fi
  if [ "$SHOW_SONAR" -eq 1 ]; then
    sonar_collect "$repo"
    if [ "$S_CONFIGURED" = "true" ]; then
      has=1
      if [ "$S_OK" != "true" ]; then
        row "sonar" "${RED}${S_ERR}${NC}"
      else
        render_sonar_row
      fi
    fi
  fi

  body="$RENDER_OUT"
  RENDER_OUT="$section_out"
  if [ -n "$body" ]; then
    RENDER_OUT="$RENDER_OUT$body"
  else
    emit "  ${GREEN}✓ clean${NC}"
  fi
  emit "${BOLD}${CYAN}╰$(repeat_char '─' "$((WIDTH - 1))")${NC}"

  REPO_HAS_CONTENT=$has
}

render_audit() {  # returns 0 if produced output
  local repo="$1" produced=1 f base
  local active=() archive=()
  while IFS= read -r f; do
    [ -z "$f" ] && continue
    base=$(basename "$f")
    if printf '%s' "$base" | grep -qE '^[0-9]{4}-[0-9]{2}-[0-9]{2}'; then archive+=("$f"); else active+=("$f"); fi
  done < <(find_audit_files "$repo")
  [ "${#active[@]}" -eq 0 ] && [ "${#archive[@]}" -eq 0 ] && return 1

  local shown=0 gst rel tag lineno text n
  for f in "${active[@]}"; do
    [ "$shown" -ge "$MAX_AUDIT_FILES" ] && break
    gst=$(git -C "$repo" status -s -- "$f" 2>/dev/null)
    gst=$(printf '%s' "$gst" | sed 's/^[[:space:]]*//'); gst=${gst:0:2}; gst=$(rstrip "$gst")
    rel=${f#"$repo"/}; tag=""
    [ "$gst" = "??" ] && tag=" ${DIM}(untracked)${NC}"
    [ "$gst" = "M" ] && tag=" ${DIM}(modified)${NC}"
    row "audit" "${RED}${rel}${NC}${tag}"
    shown=$((shown + 1)); n=0
    while IFS=$'\t' read -r lineno text; do
      [ -z "$lineno" ] && continue
      [ "$n" -ge "$AUDIT_ITEMS_PER_FILE" ] && break
      row "" "  ${YELLOW}☐${NC} ${text}"; n=$((n + 1))
    done < <(list_open_items "$repo" "$f")
  done

  if [ "${#archive[@]}" -gt 0 ]; then
    local latest="${archive[$((${#archive[@]} - 1))]}" mr total=0 cnt
    mr=$(basename "$latest")
    for f in "${archive[@]}"; do cnt=$(list_open_items "$repo" "$f" | grep -c .); total=$((total + cnt)); done
    row "audit" "${DIM}${#archive[@]} historical files"
    if [ "$total" -gt 0 ]; then
      row "" "  ${YELLOW}${total} open items${NC} across archive  ${DIM}(latest: ${mr})${NC}"
      n=0
      while IFS=$'\t' read -r lineno text; do
        [ -z "$lineno" ] && continue
        [ "$n" -ge "$ARCHIVE_ITEMS" ] && break
        row "" "  ${YELLOW}☐${NC} ${text}"; n=$((n + 1))
      done < <(list_open_items "$repo" "$latest")
    fi
  fi
  return 0
}

render_roadmap() {
  local repo="$1" f rel lineno text n produced=1 any=0
  while IFS= read -r f; do
    [ -z "$f" ] && continue
    rel=${f#"$repo"/}
    local items; items=$(list_open_items "$repo" "$f")
    [ -z "$items" ] && continue
    any=1
    row "roadmap" "${BLUE}${rel}${NC}"
    n=0
    while IFS=$'\t' read -r lineno text; do
      [ -z "$lineno" ] && continue
      [ "$n" -ge "$ROADMAP_ITEMS_PER_FILE" ] && break
      row "" "  ${CYAN}☐${NC} ${text}  ${DIM}:${lineno}${NC}"; n=$((n + 1))
    done <<< "$items"
  done < <(find_roadmap_files "$repo")
  [ "$any" -eq 1 ] && return 0 || return 1
}

render_sonar_row() {
  local bugs vulns hot smells cov dup bcol vcol hcol
  bugs=$(sonar_metric bugs); vulns=$(sonar_metric vulnerabilities)
  hot=$(sonar_metric security_hotspots); smells=$(sonar_metric code_smells)
  cov=$(sonar_metric coverage); dup=$(sonar_metric duplicated_lines_density)
  bcol=$NC; [ "$bugs" != "0" ] && [ "$bugs" != "-" ] && bcol=$RED
  vcol=$NC; [ "$vulns" != "0" ] && [ "$vulns" != "-" ] && vcol=$RED
  hcol=$NC; [ "$hot" != "0" ] && [ "$hot" != "-" ] && hcol=$YELLOW
  row "sonar" "bugs:${bcol}${bugs}${NC}  vulns:${vcol}${vulns}${NC}  hotspots:${hcol}${hot}${NC}  smells:${smells}  coverage:${cov}%  dup:${dup}%"
}

# ── width / color resolution ─────────────────────────────────────────────────
resolve_width() {
  if [ -n "$WIDTH_OVERRIDE" ]; then printf '%s' "$WIDTH_OVERRIDE"; return; fi
  if [ -n "$COLUMNS" ] && printf '%s' "$COLUMNS" | grep -qE '^[0-9]+$'; then printf '%s' "$COLUMNS"; return; fi
  tput cols 2>/dev/null || printf '80'
}

want_color() {
  [ "$NO_COLOR_FLAG" -eq 1 ] && return 1
  [ -n "${NO_COLOR+x}" ] && return 1
  [ -t 1 ] || return 1
  return 0
}

