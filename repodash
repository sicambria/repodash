[ -d "$BASE_DIR" ] || { printf 'Directory not found: %s\n' "$BASE_DIR" >&2; exit 1; }

discover_repos

if [ "$AS_JSON" -eq 1 ]; then
  gen=$(date -u +%Y-%m-%dT%H:%M:%SZ 2>/dev/null)
  parts=()
  for repo in "${REPOS[@]}"; do parts+=("$(repo_json "$repo")"); done
  printf '{\n  "base_dir": %s,\n  "generated_at": %s,\n  "repos": [%s],\n  "schema_version": %d\n}\n' \
    "$(json_str "$(abspath "$BASE_DIR")")" "$(json_str "$gen")" \
    "$(join_json , "${parts[@]}")" "$SCHEMA_VERSION"
  exit 0
fi

if [ "${#REPOS[@]}" -eq 0 ]; then
  printf 'No git repositories found in: %s\n' "$BASE_DIR"
  exit 0
fi

if want_color; then set_palette 1; else set_palette 0; fi
WIDTH=$(resolve_width)

n=${#REPOS[@]}
word="repos"; [ "$n" -eq 1 ] && word="repo"
printf '%s\n' "${BOLD}${MAGENTA}repodash${NC}  ${DIM}${BASE_DIR}${NC}  ${n} ${word}"

dirty=0
for repo in "${REPOS[@]}"; do
  render_repo "$repo"
  if [ "$ONLY_DIRTY" -eq 1 ] && [ "$REPO_HAS_CONTENT" -eq 0 ]; then continue; fi
  [ "$REPO_HAS_CONTENT" -eq 1 ] && dirty=$((dirty + 1))
  printf '%s' "$RENDER_OUT"
done

word="repos"; [ "$n" -eq 1 ] && word="repo"
printf '\n%s\n' "${BOLD}Summary${NC}  ${dirty}/${n} ${word} have items"
