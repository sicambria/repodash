#!/usr/bin/env bash
# repodash pre-push gate: full test suite, bash syntax check, JSON parity
# gate, and a personal-data/secrets scan of everything about to be pushed.
#
# Installed via scripts/install-hooks.sh (sets core.hooksPath). To bypass in
# a genuine emergency: git push --no-verify.
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"
zero_sha="0000000000000000000000000000000000000000"

echo "==> pre-push: running full test suite with coverage threshold"
bash scripts/test_with_coverage.sh

echo "==> pre-push: bash syntax check"
bash -n repodash

echo "==> pre-push: JSON parity gate (python vs bash --json)"
bash tests/test_parity.sh

echo "==> pre-push: scanning outgoing commits for secrets / personal data"
had_ref=0
while read -r local_ref local_sha remote_ref remote_sha; do
    had_ref=1
    if [ "$local_sha" = "$zero_sha" ]; then
        continue # deleting a ref: nothing new to scan
    fi
    scripts/git-hooks/scan-personal-data.sh "$remote_sha" "$local_sha"
done

if [ "$had_ref" -eq 0 ]; then
    exit 0
fi

echo "==> pre-push: all checks passed"
