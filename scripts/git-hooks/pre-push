#!/usr/bin/env bash
# repodash pre-push gate: full test suite, bash syntax check, JSON parity
# gate, and a personal-data/secrets scan of everything about to be pushed.
#
# Installed via scripts/install-hooks.sh (sets core.hooksPath). To bypass in
# a genuine emergency: git push --no-verify.
#
# Set REPODASH_SKIP_SLOW_CHECKS=1 to skip test suite + parity gate (for
# testing the hook itself rapidly; never use this for real pushes).
set -euo pipefail
trap 'echo "==> pre-push: FAILED at line $LINENO" >&2' ERR

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"
zero_sha="0000000000000000000000000000000000000000"

# --- read all refs from git's stdin FIRST, before any subprocess calls ---
ref_lines=()
while IFS= read -r line || [ -n "$line" ]; do
    ref_lines+=("$line")
done
# -------------------------------------------------------------------------

skip_slow="${REPODASH_SKIP_SLOW_CHECKS:-0}"

if [ "$skip_slow" != "1" ]; then
    echo "==> pre-push: running full test suite with coverage threshold"
    bash scripts/test_with_coverage.sh </dev/null

    echo "==> pre-push: bash syntax check"
    bash -n repodash

    echo "==> pre-push: JSON parity gate (python vs bash --json)"
    bash tests/test_parity.sh </dev/null
else
    echo "==> pre-push: REPODASH_SKIP_SLOW_CHECKS=1 — skipping test suite and parity gate"
    echo "==> pre-push: bash syntax check"
    bash -n repodash
fi

# --- process captured refs for secrets / personal-data scan ---
echo "==> pre-push: scanning outgoing commits for secrets / personal data"
had_ref=0

for line in "${ref_lines[@]}"; do
    line="${line#"${line%%[![:space:]]*}"}"
    line="${line%"${line##*[![:space:]]}"}"
    [ -z "$line" ] && continue

    read -r local_ref local_sha remote_ref remote_sha rest <<<"$line"
    if [ -z "$local_ref" ] || [ -z "$local_sha" ] || [ -z "$remote_ref" ] || [ -z "$remote_sha" ] || [ -n "$rest" ]; then
        echo "==> pre-push: WARNING: malformed stdin line, skipping: $line" >&2
        had_ref=1
        continue
    fi
    had_ref=1
    if [ "$local_sha" = "$zero_sha" ]; then
        continue
    fi
    scripts/git-hooks/scan-personal-data.sh "$remote_sha" "$local_sha"
done

if [ "$had_ref" -eq 0 ]; then
    echo "==> pre-push: no refs found on stdin, nothing to scan"
fi

echo "==> pre-push: all checks passed"
